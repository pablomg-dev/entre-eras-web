---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const newsEntries = await getCollection('news');
  return newsEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Layout title={`${entry.data.title} | EE Estilo Editorial`}>
	<article class="max-w-4xl mx-auto py-12 px-4 shadow-sm bg-white mt-12 mb-24 border-t-8 border-ee-green-muted">
		<header class="mb-12 text-center border-b pb-12 border-ee-brown-dark/10">
			<span class="font-dm-serif-display text-ee-terracotta uppercase tracking-[0.3em] mb-4 block">{entry.data.category}</span>
			<h1 class="font-playfair text-5xl md:text-6xl text-ee-brown-dark leading-tight mb-8 drop-shadow-sm">{entry.data.title}</h1>
			<p class="font-dm-serif text-ee-subhead text-ee-cyan-muted italic max-w-2xl mx-auto mb-8 font-light">
				{entry.data.description}
			</p>
			<div class="flex items-center justify-center gap-6 font-poppins text-xs uppercase tracking-widest opacity-60">
				<span>Por <span class="text-ee-brown-dark font-bold">{entry.data.author}</span>{entry.data.authorSocial && <a href={entry.data.authorSocial} target="_blank" rel="noopener noreferrer" class="text-ee-terracotta hover:underline ml-1">@madrehierbas</a>}</span>
				<span class="w-1 h-1 bg-ee-brown-dark rounded-full"></span>
				<time>{entry.data.pubDate.toLocaleDateString('es-ES', { month: 'long', year: 'numeric' })}</time>
			</div>
			{entry.data.authorImage && (
				<div class="flex justify-center mt-4">
					<img 
						src={entry.data.authorImage} 
						alt={entry.data.author} 
						class="w-16 h-16 md:w-20 md:h-20 rounded-full object-cover"
					/>
				</div>
			)}
		</header>

		<div class="mb-8 md:mb-12 aspect-[3/2] md:aspect-[4/3] overflow-hidden rounded-sm shadow-lg">
			<img src={entry.data.image} alt={entry.data.title} class="w-full h-full object-contain bg-ee-sand/10" />
		</div>

		{entry.data.gallery && entry.data.gallery.length > 0 && (
			<div class="mb-10 grid grid-cols-2 md:grid-cols-3 gap-3 md:gap-4">
				{entry.data.gallery.map((img: string, index: number) => (
					<div class="overflow-hidden aspect-[4/3] shadow-md border border-ee-brown-dark/10">
						<img 
							src={img} 
							alt={`${entry.data.title} - Imagen ${index + 1}`} 
							class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-500"
						/>
					</div>
				))}
			</div>
		)}

		<div class="prose prose-lg prose-stone max-w-none font-poppins text-sm md:text-base leading-[1.8] text-ee-gray-dark">
			<Content />
		</div>

		<footer class="mt-20 pt-12 border-t-4 border-ee-brown-dark flex flex-col md:flex-row justify-between items-center gap-8">
			<a href="/" class="font-dm-serif-display text-ee-brown-dark uppercase tracking-widest hover:text-ee-terracotta">← Volver al Inicio</a>
		</footer>
	</article>
</Layout>

<style is:global>
	.prose p {
		margin-bottom: 2rem;
	}
	.prose > p:first-of-type::first-letter {
		float: left;
		font-family: 'Playfair Display', serif;
		font-size: 2.5rem !important;
		line-height: 0.7;
		padding-right: 0.5rem;
		padding-top: 0.15rem;
		color: #c46d5e;
		font-weight: 700;
	}
	@media (min-width: 640px) {
		.prose > p:first-of-type::first-letter {
			font-size: 3rem !important;
		}
	}
	@media (min-width: 768px) {
		.prose > p:first-of-type::first-letter {
			font-size: 3.5rem !important;
			padding-top: 0.1rem;
		}
	}
	@media (min-width: 1024px) {
		.prose > p:first-of-type::first-letter {
			font-size: 4.5rem !important;
		}
	}
	@media (min-width: 1280px) {
		.prose > p:first-of-type::first-letter {
			font-size: 5rem !important;
		}
	}
	.prose h2 {
		font-family: 'DM Serif Display', serif;
		font-size: 2.25rem;
		margin-top: 3rem;
		margin-bottom: 1.5rem;
		color: #232019;
		border-left: 4px solid #80956d;
		padding-left: 1.5rem;
	}
	.prose img {
		width: 100%;
		height: auto;
		max-width: 100%;
		border-radius: 0.5rem;
		margin: 2rem 0;
		box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
	}
	@media (min-width: 768px) {
		.prose img {
			max-width: 80%;
			margin: 3rem auto;
		}
	}
</style>
