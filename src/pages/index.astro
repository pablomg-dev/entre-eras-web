---
import Layout from "../layouts/Layout.astro";
import SectionHeader from "../components/SectionHeader.astro";
import SectionFeatured from "../components/SectionFeatured.astro";
import ArticleCard from "../components/ArticleCard.astro";
import MagazineCover from "../components/MagazineCover.astro";
import SubscriptionForm from "../components/SubscriptionForm";
import { getCollection } from "astro:content";

const allNews = await getCollection("news");
const featuredNews = allNews
  .filter((n) => n.data.isFeatured)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 4);
const recentNews = allNews.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const healthNews = recentNews
  .filter((n) => n.data.category === "SALUD INTEGRAL")
  .slice(0, 4);
const societyNews = recentNews
  .filter((n) => n.data.category === "SOCIEDAD EN TRANSICIÓN")
  .slice(0, 4);
const interiorNews = recentNews
  .filter((n) => n.data.category === "CAMINO INTERIOR")
  .slice(0, 4);
const huertNews = recentNews
  .filter((n) => n.data.category === "HUERTO ACTIVO")
  .slice(0, 4);

const allMagazines = await getCollection("magazines");
const latestMagazines = allMagazines
  .sort((a, b) => b.data.editionDate.getTime() - a.data.editionDate.getTime())
  .slice(0, 4);
---

<Layout title="EE - Estilo Editorial | El Periódico Holístico Moderno">
  <main class="space-y-16">
    <!-- Primera Parte: Sociedad -->
    <section class="py-12 border-b-2 border-ee-brown-dark/5">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-8">
        <!-- Izquierda: VOCES Entrevista -->
        <div class="lg:col-span-2">
          <h2 class="font-dm-serif-display text-lg text-ee-terracotta uppercase tracking-[0.1em] mb-6 pb-3 border-b-4 border-ee-terracotta">
            Voces
          </h2>
          {
            featuredNews[0] && (
              <ArticleCard
                article={{
                  ...featuredNews[0].data,
                  slug: featuredNews[0].slug,
                }}
                size="large"
              />
            )
          }
        </div>
        <!-- Derecha: Categorías -->
        <div class="lg:col-span-3 grid grid-cols-2 gap-4">
          <a href="/categoria/bioconstruccion" class="group relative overflow-hidden aspect-[4/3] border border-ee-brown-dark/10">
            <img src="https://images.unsplash.com/photo-1518780664697-55e3ad937233?w=400&h=300&fit=crop" alt="Bioconstrucción" class="w-full h-full object-cover grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-500" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent"></div>
            <div class="absolute bottom-0 left-0 p-3">
              <span class="font-dm-serif-display text-[10px] text-white/70 uppercase tracking-[0.1em]">Categoría</span>
              <h3 class="font-playfair text-lg text-white">Bioconstrucción</h3>
            </div>
          </a>
          <a href="/categoria/huerto-vivo" class="group relative overflow-hidden aspect-[4/3] border border-ee-brown-dark/10">
            <img src="https://images.unsplash.com/photo-1416879595882-3373a0480b5b?w=400&h=300&fit=crop" alt="Huerto Vivo" class="w-full h-full object-cover grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-500" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent"></div>
            <div class="absolute bottom-0 left-0 p-3">
              <span class="font-dm-serif-display text-[10px] text-white/70 uppercase tracking-[0.1em]">Categoría</span>
              <h3 class="font-playfair text-lg text-white">Huerto Vivo</h3>
            </div>
          </a>
          <a href="/categoria/nuevos-vinculos" class="group relative overflow-hidden aspect-[4/3] border border-ee-brown-dark/10">
            <img src="https://images.unsplash.com/photo-1529156069898-49953e39b3ac?w=400&h=300&fit=crop" alt="Nuevos Vínculos" class="w-full h-full object-cover grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-500" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent"></div>
            <div class="absolute bottom-0 left-0 p-3">
              <span class="font-dm-serif-display text-[10px] text-white/70 uppercase tracking-[0.1em]">Categoría</span>
              <h3 class="font-playfair text-lg text-white">Nuevos Vínculos</h3>
            </div>
          </a>
          <a href="/categoria/alimentacion-consciente" class="group relative overflow-hidden aspect-[4/3] border border-ee-brown-dark/10">
            <img src="https://images.unsplash.com/photo-1504674900247-0877df9cc836?w=400&h=300&fit=crop" alt="Alimentación" class="w-full h-full object-cover grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-500" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent"></div>
            <div class="absolute bottom-0 left-0 p-3">
              <span class="font-dm-serif-display text-[10px] text-white/70 uppercase tracking-[0.1em]">Categoría</span>
              <h3 class="font-playfair text-lg text-white">Alimentación</h3>
            </div>
          </a>
          <a href="/categoria/gestacion-y-crianza" class="group relative overflow-hidden aspect-[4/3] border border-ee-brown-dark/10 col-span-2">
            <img src="https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?w=800&h=300&fit=crop" alt="Gestación" class="w-full h-full object-cover grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-500" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent"></div>
            <div class="absolute bottom-0 left-0 p-3">
              <span class="font-dm-serif-display text-[10px] text-white/70 uppercase tracking-[0.1em]">Categoría</span>
              <h3 class="font-playfair text-lg text-white">Gestación</h3>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- Secciones del Menu -->
    <section class="py-12 border-b-2 border-ee-brown-dark/5">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <a href="/categoria/voces" class="group relative overflow-hidden aspect-[3/4] border border-ee-brown-dark/10">
          <img src="/sociedad-1.jpeg" alt="Sociedad" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent"></div>
          <div class="absolute bottom-0 left-0 p-4">
            <h3 class="font-dm-serif-display text-lg text-white uppercase tracking-wider">Sociedad</h3>
          </div>
        </a>
        <a href="/categoria/huerto-vivo" class="group relative overflow-hidden aspect-[3/4] border border-ee-brown-dark/10">
          <img src="/permacultura-1.jpeg" alt="Permacultura" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent"></div>
          <div class="absolute bottom-0 left-0 p-4">
            <h3 class="font-dm-serif-display text-lg text-white uppercase tracking-wider">Permacultura</h3>
          </div>
        </a>
        <a href="/categoria/alimentacion-consciente" class="group relative overflow-hidden aspect-[3/4] border border-ee-brown-dark/10">
          <img src="/salud-1.jpeg" alt="Salud Integral" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent"></div>
          <div class="absolute bottom-0 left-0 p-4">
            <h3 class="font-dm-serif-display text-lg text-white uppercase tracking-wider">Salud Integral</h3>
          </div>
        </a>
        <a href="/categoria/tiempo-natural" class="group relative overflow-hidden aspect-[3/4] border border-ee-brown-dark/10">
          <img src="/caminointerior-1.jpeg" alt="Camino Interior" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent"></div>
          <div class="absolute bottom-0 left-0 p-4">
            <h3 class="font-dm-serif-display text-lg text-white uppercase tracking-wider">Camino Interior</h3>
          </div>
        </a>
      </div>
    </section>

    <!-- Terracotta Separator Strip -->
    <div
      class="bg-ee-terracotta text-white py-12 px-8 -mx-4 sm:-mx-6 lg:-mx-8 text-center shadow-inner relative overflow-hidden"
    >
      <div
        class="absolute inset-0 opacity-10 flex items-center justify-center select-none pointer-events-none"
      >
        <span class="font-playfair text-9xl italic">Vida Consciente</span>
      </div>
      <div class="relative z-10 max-w-4xl mx-auto">
        <h3
          class="font-dm-serif-display text-2xl md:text-3xl uppercase tracking-[0.3em] mb-4"
        >
          Membresía Digital
        </h3>
        <p
          class="font-dm-serif text-xl italic text-white/80 mb-8 max-w-lg mx-auto"
        >
          Únete para acceder a ediciones exclusivas y contenido de archivo.
        </p>
        <a
          href="#subscribe"
          class="inline-block border-2 border-white px-10 py-3 font-dm-serif-display text-sm tracking-widest uppercase hover:bg-white hover:text-ee-terracotta transition-all shadow-lg scroll-smooth"
          >Suscribirme hoy</a
        >
      </div>
    </div>

    <!-- Banner de Anuncio -->
    <div
      class="w-full bg-ee-brown-dark h-32 flex items-center justify-center opacity-10 group cursor-pointer relative overflow-hidden"
    >
      <div
        class="absolute inset-0 flex items-center justify-center group-hover:bg-ee-terracotta/10 transition-colors"
      >
        <span
          class="font-dm-serif text-3xl italic tracking-widest opacity-30 select-none"
          >ESPACIO PUBLICITARIO</span
        >
      </div>
    </div>

    <!-- Huerto Activo Section -->
    <SectionFeatured
      sectionTitle="Huerto Activo"
      color="green"
      featured={huertNews[0] ? { ...huertNews[0].data, slug: huertNews[0].slug } : null}
      articles={huertNews.slice(0, 3).map((a) => ({ ...a.data, slug: a.slug }))}
    />

    <!-- Salud Section -->
    <SectionFeatured
      sectionTitle="Salud & Bienestar"
      color="cyan"
      featured={healthNews[0] ? { ...healthNews[0].data, slug: healthNews[0].slug } : null}
      articles={healthNews.slice(0, 3).map((a) => ({ ...a.data, slug: a.slug }))}
    />

    <!-- Revista Archive Grid Preview -->
    <section>
      <SectionHeader title="Últimas Revistas" color="terracotta" />
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-12">
        {latestMagazines.map((mag) => <MagazineCover magazine={mag.data} />)}
        {
          latestMagazines.length === 0 && (
            <div class="col-span-full py-20 text-center bg-ee-sand/10 border-ee-tile opacity-30">
              Cargando ediciones digitales...
            </div>
          )
        }
      </div>
      <div class="text-center mt-12">
        <a
          href="/revista"
          class="inline-block border-b-4 border-ee-terracotta/20 text-ee-terracotta font-dm-serif-display text-2xl uppercase tracking-[0.2em] px-8 py-2 hover:border-ee-terracotta hover:scale-110 transition-all duration-300"
          >Explorar Archivo Completo</a
        >
      </div>
    </section>

    <!-- Sociedad section -->
    <SectionFeatured
      sectionTitle="Sociedad en Transición"
      color="brown"
      featured={societyNews[0] ? { ...societyNews[0].data, slug: societyNews[0].slug } : null}
      articles={societyNews.slice(0, 3).map((a) => ({ ...a.data, slug: a.slug }))}
    />

    <!-- Camino Interior section -->
    <SectionFeatured
      sectionTitle="Camino Interior"
      color="green"
      featured={interiorNews[0] ? { ...interiorNews[0].data, slug: interiorNews[0].slug } : null}
      articles={interiorNews.slice(0, 3).map((a) => ({ ...a.data, slug: a.slug }))}
    />

    <!-- Subscription Call to Action -->
    <div id="subscribe" class="scroll-mt-24 pb-20">
      <SubscriptionForm client:load />
    </div>
  </main>
</Layout>
