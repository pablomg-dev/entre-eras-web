---
import Layout from "../layouts/Layout.astro";
import SectionHeader from "../components/SectionHeader.astro";
import ArticleCard from "../components/ArticleCard.astro";
import MagazineCover from "../components/MagazineCover.astro";
import SubscriptionForm from "../components/SubscriptionForm";
import { getCollection } from "astro:content";

const allNews = await getCollection("news");
const featuredNews = allNews
  .filter((n) => n.data.isFeatured)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 4);
const recentNews = allNews.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const healthNews = recentNews
  .filter((n) => n.data.category === "SALUD INTEGRAL")
  .slice(0, 4);
const societyNews = recentNews
  .filter((n) => n.data.category === "SOCIEDAD EN TRANSICIÓN")
  .slice(0, 4);
const interiorNews = recentNews
  .filter((n) => n.data.category === "CAMINO INTERIOR")
  .slice(0, 4);
const huertNews = recentNews
  .filter((n) => n.data.category === "HUERTO ACTIVO")
  .slice(0, 4);

const allMagazines = await getCollection("magazines");
const latestMagazines = allMagazines
  .sort((a, b) => b.data.editionDate.getTime() - a.data.editionDate.getTime())
  .slice(0, 4);
---

<Layout title="EE - Estilo Editorial | El Periódico Holístico Moderno">
  <main class="space-y-16">
    <!-- Hero Section -->
    <section class="py-12 border-b-2 border-ee-brown-dark/5">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        {
          featuredNews[0] && (
            <div class="col-span-1">
              <ArticleCard
                article={{
                  ...featuredNews[0].data,
                  slug: featuredNews[0].slug,
                }}
                size="large"
              />
            </div>
          )
        }
        <div class="col-span-1 flex flex-col justify-start">
          {
            featuredNews
              .slice(1, 4)
              .map((article) => (
                <ArticleCard
                  article={{ ...article.data, slug: article.slug }}
                  size="list"
                />
              ))
          }
          {
            featuredNews.length < 4 && (
              <div class="py-6 border-b border-dashed border-ee-brown-dark/10 group cursor-pointer opacity-40">
                <div class="flex gap-4 items-center">
                  <div class="flex-grow">
                    <span class="font-dm-serif-display text-[10px] text-ee-terracotta uppercase tracking-[0.1em]">
                      PRÓXIMAMENTE
                    </span>
                    <h3 class="font-playfair text-lg text-ee-brown-dark group-hover:text-ee-green-muted transition-colors leading-tight">
                      Más notas sobre nuevos paradigmas y vida holística en
                      camino...
                    </h3>
                  </div>
                </div>
              </div>
            )
          }
        </div>
      </div>
    </section>

    <!-- Huerto Activo Section -->
    <section>
      <SectionHeader title="Huerto Activo" color="green" />
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        {
          huertNews[0] && (
            <div class="col-span-1">
              <ArticleCard
                article={{ ...huertNews[0].data, slug: huertNews[0].slug }}
                size="large"
              />
            </div>
          )
        }
        <div class="col-span-1 flex flex-col">
          {
            huertNews
              .slice(1)
              .map((article) => (
                <ArticleCard
                  article={{ ...article.data, slug: article.slug }}
                  size="list"
                />
              ))
          }
          {
            huertNews.length < 2 && (
              <div class="p-6 border-2 border-dashed border-ee-green-muted/20 text-center opacity-30 italic">
                Más contenido de huerto próximamente...
              </div>
            )
          }
        </div>
      </div>
    </section>

    <!-- Salud Section (Big on left, list on right) -->
    <section>
      <SectionHeader title="Salud & Bienestar" color="cyan" />
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        {
          healthNews[0] && (
            <div class="col-span-1">
              <ArticleCard
                article={{ ...healthNews[0].data, slug: healthNews[0].slug }}
                size="large"
              />
            </div>
          )
        }
        <div class="col-span-1 flex flex-col">
          {
            healthNews
              .slice(1)
              .map((article) => (
                <ArticleCard
                  article={{ ...article.data, slug: article.slug }}
                  size="list"
                />
              ))
          }
          {
            healthNews.length < 2 && (
              <div class="p-6 border-2 border-dashed border-ee-cyan-muted/20 text-center opacity-30 italic">
                Más contenido de salud próximamente...
              </div>
            )
          }
        </div>
      </div>
    </section>

    <!-- Subscription Call to Action -->
    <div id="subscribe" class="scroll-mt-24">
      <SubscriptionForm client:load />
    </div>

    <!-- Revista Archive Grid Preview -->
    <section>
      <SectionHeader title="Últimas Revistas" color="terracotta" />
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-12">
        {latestMagazines.map((mag) => <MagazineCover magazine={mag.data} />)}
        {
          latestMagazines.length === 0 && (
            <div class="col-span-full py-20 text-center bg-ee-sand/10 border-ee-tile opacity-30">
              Cargando ediciones digitales...
            </div>
          )
        }
      </div>
      <div class="text-center mt-12">
        <a
          href="/revista"
          class="inline-block border-b-4 border-ee-terracotta/20 text-ee-terracotta font-dm-serif-display text-2xl uppercase tracking-[0.2em] px-8 py-2 hover:border-ee-terracotta hover:scale-110 transition-all duration-300"
          >Explorar Archivo Completo</a
        >
      </div>
    </section>

    <!-- Sociedad section -->
    <section>
      <SectionHeader title="Sociedad en Transición" color="brown" />
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        {
          societyNews.map((article) => (
            <ArticleCard
              article={{ ...article.data, slug: article.slug }}
              size="small"
            />
          ))
        }
        {
          societyNews.length === 0 && (
            <div class="col-span-full py-12 text-center opacity-20 font-dm-serif italic">
              Nuevos paradigmas en camino...
            </div>
          )
        }
      </div>
    </section>

    <!-- Camino Interior section -->
    <section class="pb-20">
      <SectionHeader title="Camino Interior" color="green" />
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        {
          interiorNews.map((article) => (
            <ArticleCard
              article={{ ...article.data, slug: article.slug }}
              size="small"
            />
          ))
        }
        {
          interiorNews.length === 0 && (
            <div class="col-span-full py-12 text-center opacity-20 font-dm-serif italic">
              Explorando el tiempo natural...
            </div>
          )
        }
      </div>
    </section>
  </main>
</Layout>
