---
import Layout from '../layouts/Layout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ArticleCard from '../components/ArticleCard.astro';
import MagazineCover from '../components/MagazineCover.astro';
import SubscriptionForm from '../components/SubscriptionForm';
import { getCollection } from 'astro:content';

const allNews = await getCollection('news');
const featuredNews = allNews.filter(n => n.data.isFeatured).slice(0, 4); // Fetch 4 for Hero
const recentNews = allNews.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const healthNews = recentNews.filter(n => n.data.category === 'SALUD INTEGRAL').slice(0, 4);
const societyNews = recentNews.filter(n => n.data.category === 'SOCIEDAD EN TRANSICIÓN').slice(0, 4);
const interiorNews = recentNews.filter(n => n.data.category === 'CAMINO INTERIOR').slice(0, 4);

const allMagazines = await getCollection('magazines');
const latestMagazines = allMagazines.sort((a, b) => b.data.editionDate.getTime() - a.data.editionDate.getTime()).slice(0, 4);
---

<Layout title="EE - Estilo Editorial | El Periódico Holístico Moderno">
	<main class="space-y-16">
		
		<!-- Hero Section -->
		<section class="grid grid-cols-1 md:grid-cols-12 gap-10 min-h-[600px] py-6">
			{featuredNews[0] && (
				<div class="col-span-1 md:col-span-8">
					<ArticleCard article={featuredNews[0].data} size="large" />
				</div>
			)}
			<div class="col-span-1 md:col-span-4 flex flex-col gap-8">
				{featuredNews.slice(1, 4).map(article => (
					<ArticleCard article={article.data} size="small" />
				))}
				{featuredNews.length < 4 && (
					<div class="bg-ee-sand p-8 text-ee-brown-dark shadow-xl border-4 border-white transform hover:-rotate-1 transition-transform">
						<h3 class="font-dm-serif-display text-2xl uppercase mb-3">EE Consciente</h3>
						<p class="font-poppins text-ee-body mb-6">Próximamente más notas sobre nuevos paradigmas y vida holística.</p>
					</div>
				)}
			</div>
		</section>

		<!-- Terracotta Separator Strip -->
		<div class="bg-ee-terracotta text-white py-12 px-8 -mx-4 sm:-mx-6 lg:-mx-8 text-center shadow-inner relative overflow-hidden">
			<div class="absolute inset-0 opacity-10 flex items-center justify-center select-none pointer-events-none">
				<span class="font-playfair text-9xl italic">Vida Consciente</span>
			</div>
			<div class="relative z-10 max-w-4xl mx-auto">
				<h3 class="font-dm-serif-display text-2xl md:text-3xl uppercase tracking-[0.3em] mb-4">Membresía Digital</h3>
				<p class="font-dm-serif text-xl italic text-white/80 mb-8 max-w-lg mx-auto">Únete para acceder a ediciones exclusivas y contenido de archivo.</p>
				<a href="#subscribe" class="inline-block border-2 border-white px-10 py-3 font-dm-serif-display text-sm tracking-widest uppercase hover:bg-white hover:text-ee-terracotta transition-all shadow-lg">Suscribirme hoy</a>
			</div>
		</div>

		<!-- Banner de Anuncio -->
		<div class="w-full bg-ee-brown-dark h-32 flex items-center justify-center opacity-10 group cursor-pointer relative overflow-hidden">
			<div class="absolute inset-0 flex items-center justify-center group-hover:bg-ee-terracotta/10 transition-colors">
				<span class="font-dm-serif text-3xl italic tracking-widest opacity-30 select-none">ESPACIO PUBLICITARIO</span>
			</div>
		</div>

		<!-- Salud Section (Big on left, list on right) -->
		<section>
			<SectionHeader title="Salud & Bienestar" color="cyan" />
			<div class="grid grid-cols-1 md:grid-cols-2 gap-12">
				{healthNews[0] && (
					<div class="col-span-1">
						<ArticleCard article={healthNews[0].data} size="large" />
					</div>
				)}
				<div class="col-span-1 flex flex-col">
					{healthNews.slice(1).map(article => (
						<ArticleCard article={article.data} size="list" />
					))}
					{healthNews.length < 2 && (
						<div class="p-6 border-2 border-dashed border-ee-cyan-muted/20 text-center opacity-30 italic">Más contenido de salud próximamente...</div>
					)}
				</div>
			</div>
		</section>

		<!-- Subscription Call to Action -->
		<div id="subscribe" class="scroll-mt-24">
			<SubscriptionForm client:load />
		</div>

		<!-- Revista Archive Grid Preview -->
		<section>
			<SectionHeader title="Últimas Revistas" color="terracotta" />
			<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-12">
				{latestMagazines.map(mag => (
					<MagazineCover magazine={mag.data} />
				))}
				{latestMagazines.length === 0 && (
					<div class="col-span-full py-20 text-center bg-ee-sand/10 border-ee-tile opacity-30">Cargando ediciones digitales...</div>
				)}
			</div>
			<div class="text-center mt-12">
				<a href="/revista" class="inline-block border-b-4 border-ee-terracotta/20 text-ee-terracotta font-dm-serif-display text-2xl uppercase tracking-[0.2em] px-8 py-2 hover:border-ee-terracotta hover:scale-110 transition-all duration-300">Explorar Archivo Completo</a>
			</div>
		</section>

		<!-- Sociedad section -->
		<section>
			<SectionHeader title="Sociedad en Transición" color="brown" />
			<div class="grid grid-cols-1 md:grid-cols-3 gap-10">
				{societyNews.map(article => (
					<ArticleCard article={article.data} size="small" />
				))}
				{societyNews.length === 0 && (
					<div class="col-span-full py-12 text-center opacity-20 font-dm-serif italic">Nuevos paradigmas en camino...</div>
				)}
			</div>
		</section>

		<!-- Camino Interior section -->
		<section class="pb-20">
			<SectionHeader title="Camino Interior" color="green" />
			<div class="grid grid-cols-1 md:grid-cols-3 gap-10">
				{interiorNews.map(article => (
					<ArticleCard article={article.data} size="small" />
				))}
				{interiorNews.length === 0 && (
					<div class="col-span-full py-12 text-center opacity-20 font-dm-serif italic">Explorando el tiempo natural...</div>
				)}
			</div>
		</section>

	</main>
</Layout>
