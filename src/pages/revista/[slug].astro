---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const magazineEntries = await getCollection('magazines');
  return magazineEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
---

<Layout title={`${entry.data.title} | Visor Digital EE`}>
	<main class="py-12 px-4 max-w-7xl mx-auto">
		<header class="mb-12 flex flex-col md:flex-row justify-between items-center gap-8 border-b-4 border-ee-brown-dark pb-8">
			<div>
				<h1 class="font-playfair text-4xl text-ee-brown-dark mb-2 tracking-tight">{entry.data.title}</h1>
				<time class="font-dm-serif-display text-ee-terracotta uppercase tracking-[0.2em] italic">
					{entry.data.editionDate.toLocaleDateString('es-ES', { month: 'long', year: 'numeric' })}
				</time>
			</div>
			<div class="flex gap-4">
				<a href="/revista" class="bg-ee-brown-dark text-white px-8 py-3 font-dm-serif-display uppercase tracking-widest text-xs hover:bg-ee-terracotta transition-all shadow-md">
					← Volver al Archivo
				</a>
				<button class="bg-ee-green-muted text-white px-8 py-3 font-dm-serif-display uppercase tracking-widest text-xs hover:bg-ee-brown-dark transition-all shadow-md">
					Descargar PDF
				</button>
			</div>
		</header>

		{entry.data.isPremium ? (
			<div class="bg-ee-sand p-16 text-center border-4 border-white shadow-2xl skew-y-1 mb-24">
				<h2 class="font-playfair text-5xl text-ee-brown-dark mb-8">Esta es una Edición <span class="text-ee-terracotta italic font-bold">Premium</span></h2>
				<p class="font-dm-serif text-2xl text-ee-brown-dark/80 mb-12 italic max-w-xl mx-auto opacity-70">
					Debes estar suscrito para acceder al visor interactivo de esta edición especial.
				</p>
				<a href="/#subscribe" class="inline-block bg-ee-terracotta text-white px-16 py-5 font-dm-serif-display text-xl uppercase tracking-[0.2em] hover:scale-110 transition-transform shadow-xl">
					Suscribirme Ahora
				</a>
			</div>
		) : (
			<div class="relative w-full aspect-[16/9] mb-24 bg-stone-100 shadow-[0_50px_100px_-20px_rgba(35,32,25,0.45)] border-8 border-white p-2">
				{/* Visor digital (Flipbook Placeholder) */}
				<iframe 
					src={entry.data.flipbookUrl} 
					class="w-full h-full border-0 rounded-sm"
					allowfullscreen="allowfullscreen"
					scrolling="no"
					title={`Visor de ${entry.data.title}`}
				></iframe>
				
				<div class="absolute inset-0 pointer-events-none border border-ee-brown-dark/5 opacity-30 select-none"></div>
			</div>
		)}

		<section class="max-w-4xl mx-auto text-center border-t border-ee-brown-dark/20 pt-16">
			<h3 class="font-dm-serif-display text-ee-section uppercase tracking-widest text-ee-brown-dark/40 mb-12">Otras Ediciones</h3>
			<div class="grid grid-cols-2 md:grid-cols-4 gap-8 opacity-30 group hover:opacity-100 transition-opacity">
				<div class="aspect-[3/4] bg-white border border-ee-brown-dark/10 shadow-lg"></div>
				<div class="aspect-[3/4] bg-white border border-ee-brown-dark/10 shadow-lg"></div>
				<div class="aspect-[3/4] bg-white border border-ee-brown-dark/10 shadow-lg"></div>
				<div class="aspect-[3/4] bg-white border border-ee-brown-dark/10 shadow-lg"></div>
			</div>
		</section>
	</main>
</Layout>
