---
interface ProjectArticle {
  title: string;
  description: string;
  category: string;
  image: string;
  pubDate: Date;
  isFeatured?: boolean;
  slug?: string;
}

interface Props {
  article: ProjectArticle;
  size?: "large" | "medium" | "small" | "list";
  showDate?: boolean;
}

const { article, size = "small", showDate = true } = Astro.props;
const articleUrl = article.slug ? `/news/${article.slug}` : "#";
---

{
  size === "large" ? (
    <a
      href={articleUrl}
      class="block flex flex-col gap-6 mb-12 group cursor-pointer text-left"
    >
      <div class="overflow-hidden aspect-[16/9] shadow-lg border border-ee-brown-dark/10">
        <img
          src={article.image}
          alt={article.title}
          class="w-full h-full object-cover transition-all duration-500 group-hover:scale-105"
        />
      </div>
      <div class="flex flex-col gap-3">
        <span class="font-dm-serif-display text-xs md:text-sm text-ee-terracotta uppercase tracking-[0.1em]">
          {article.category}
        </span>
        <h3 class="font-playfair text-2xl md:text-3xl lg:text-4xl text-ee-brown-dark leading-tight group-hover:text-ee-terracotta transition-colors">
          {article.title}
        </h3>
        <p class="font-dm-serif text-sm md:text-base text-ee-cyan-muted italic">
          {article.description}
        </p>
        {showDate && (
          <time class="font-poppins text-xs opacity-50 uppercase tracking-widest">
            {article.pubDate.toLocaleDateString("es-ES", {
              month: "long",
              year: "numeric",
            })}
          </time>
        )}
      </div>
    </a>
  ) : size === "medium" ? (
    <a
      href={articleUrl}
      class="block flex flex-col gap-5 group cursor-pointer text-left h-full"
    >
      <div class="overflow-hidden aspect-[4/3] shadow-md border border-ee-brown-dark/10 shrink-0">
        <img
          src={article.image}
          alt={article.title}
          class="w-full h-full object-cover transition-all duration-500 group-hover:scale-105"
        />
      </div>
      <div class="flex flex-col gap-3 flex-grow">
        <span class="font-dm-serif-display text-[10px] md:text-xs text-ee-terracotta uppercase tracking-[0.1em]">
          {article.category}
        </span>
        <h3 class="font-playfair text-xl md:text-2xl text-ee-brown-dark leading-snug group-hover:text-ee-terracotta transition-colors">
          {article.title}
        </h3>
        <p class="font-dm-serif text-sm text-ee-cyan-muted italic line-clamp-3">
          {article.description}
        </p>
        {showDate && (
          <div class="mt-auto">
            <time class="font-poppins text-[10px] opacity-50 uppercase tracking-widest">
              {article.pubDate.toLocaleDateString("es-ES", {
                month: "long",
                year: "numeric",
              })}
            </time>
          </div>
        )}
      </div>
    </a>
  ) : size === "small" ? (
    <a
      href={articleUrl}
      class="block flex flex-col gap-4 group cursor-pointer mb-8"
    >
      <div class="overflow-hidden aspect-[4/3] shadow-md border border-ee-brown-dark/10">
        <img
          src={article.image}
          alt={article.title}
          class="w-full h-full object-cover transition-all duration-500 group-hover:scale-105"
        />
      </div>
      <div class="flex flex-col gap-2">
        <span class="font-dm-serif-display text-[10px] md:text-xs text-ee-terracotta uppercase tracking-[0.1em]">
          {article.category}
        </span>
        <h3 class="font-playfair text-xl md:text-2xl text-ee-brown-dark leading-snug group-hover:text-ee-green-muted transition-colors">
          {article.title}
        </h3>
        {showDate && (
          <time class="font-poppins text-[10px] opacity-50 uppercase tracking-widest">
            {article.pubDate.toLocaleDateString("es-ES", {
              month: "long",
              year: "numeric",
            })}
          </time>
        )}
      </div>
    </a>
  ) : (
    <a
      href={articleUrl}
      class="block py-4 border-b border-ee-brown-dark/10 group cursor-pointer"
    >
      <div class="flex gap-4 items-center">
        <div class="flex-grow">
          <span class="font-dm-serif-display text-[10px] text-ee-terracotta uppercase tracking-[0.1em]">
            {article.category}
          </span>
          <h3 class="font-playfair text-base md:text-lg text-ee-brown-dark group-hover:text-ee-green-muted transition-colors leading-tight">
            {article.title}
          </h3>
        </div>
        {article.image && (
          <div class="w-16 h-16 shrink-0 overflow-hidden">
            <img src={article.image} class="w-full h-full object-cover" />
          </div>
        )}
      </div>
    </a>
  )
}
